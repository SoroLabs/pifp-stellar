################################################################################
# PIFP Staging Environment Configuration
# 
# Copy this file to .env.staging and fill in with your staging environment
# details. Never commit the actual .env.staging file to version control.
################################################################################

# ============================================================================
# Docker Registry Configuration
# ============================================================================

# Docker registry URL
DOCKER_REGISTRY=ghcr.io

# Organization/namespace in registry
DOCKER_ORG=SoroLabs

# Credentials for pushing images (typically set by CI/CD)
# In GitHub Actions, these should be secrets
DOCKER_USERNAME=${DOCKER_USERNAME}
DOCKER_PASSWORD=${DOCKER_PASSWORD}

# Enable image push (set to true in CI/CD)
DOCKER_PUSH=false

# ============================================================================
# Staging Environment Variables
# ============================================================================

# Environment identifier
STAGING_ENV=staging
STAGING_NAMESPACE=pifp-staging

# Versioning
VERSION=0.1.0
LOG_LEVEL=INFO

# ============================================================================
# Backend Services - Staging Configuration
# ============================================================================

# Oracle Service Configuration
ORACLE_RPC_URL=https://soroban-testnet.stellar.org
ORACLE_HORIZON_URL=https://horizon-testnet.stellar.org
ORACLE_CONTRACT_ID=your-staging-contract-id
ORACLE_SECRET_KEY=${ORACLE_SECRET_KEY}  # Set via CI secret
ORACLE_IPFS_GATEWAY=https://ipfs.io
ORACLE_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
ORACLE_TIMEOUT_SECS=30
ORACLE_LOG_LEVEL=info

# Keeper Service Configuration
KEEPER_RPC_URL=https://soroban-testnet.stellar.org
KEEPER_HORIZON_URL=https://horizon-testnet.stellar.org
KEEPER_CONTRACT_ID=your-staging-contract-id
KEEPER_INDEXER_URL=http://indexer:5000
KEEPER_LOG_LEVEL=info

# ============================================================================
# Database Configuration
# ============================================================================

# Indexer database
DB_PATH=/workspace/backend/indexer/pifp_events.db
DB_CONNECTION_TIMEOUT=30s

# ============================================================================
# Deployment Options
# ============================================================================

# Dry run mode (simulates deployment without making changes)
DRY_RUN=false

# Build options
BUILD_CONTEXT=.
DOCKERFILE_BACKEND=Dockerfile
DOCKERFILE_KEEPER=keeper/Dockerfile
DOCKERFILE_ORACLE=backend/oracle/Dockerfile

# ============================================================================
# Logging Configuration
# ============================================================================

# Log file location
LOG_FILE=deployment.log

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# ============================================================================
# Security & Compliance
# ============================================================================

# Generate SBOM (requires syft)
GENERATE_SBOM=true

# Enable security scanning
SECURITY_SCAN=true