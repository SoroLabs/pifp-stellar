{
  "name": "pifp-keeper",
  "version": "1.0.0",
  "description": "Keeper automation bot for PIFP protocol - monitors and triggers contract tasks",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "cmd /c \"node node_modules/jest-cli/bin/jest.js --no-coverage\"",
    "docker:build": "docker build -t pifp-keeper:latest .",
    "docker:run": "docker compose up"
  },
  "keywords": ["stellar", "soroban", "keeper", "automation"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "@sentry/node": "^8.26.0",
    "@sentry/tracing": "^7.57.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
