# Keeper Configuration

# HTTP Server
PORT=3000
HOST=0.0.0.0

# Monitoring
POLL_INTERVAL_MS=30000

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ADDRESS=

# Keeper Wallet (for submitting transactions)
KEEPER_SECRET_KEY=

# Logging
LOG_LEVEL=info

# P2P Gossip Mesh
P2P_BOOTSTRAP_PEERS=
P2P_GOSSIP_INTERVAL_MS=15000
P2P_GOSSIP_TIMEOUT_MS=5000
